          <% } %>

        </div>
      </div>
    </div>
  </header>

  <main class="relative px-4 pb-12 overflow-hidden lg:px-12 lg:pb-48 bg-gradient-to-b from-blue-50 via-blue-200 to-blue-400">

    <!-- <div class="absolute flex items-center gap-2 text-blue-600 lg:px-2 top-4 lg:left-5 lg:text-lg">
      <div class="relative">
        <svg class="w-4 h-4 lg:w-5 lg:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
        </svg>
        <div id="connection-status" class="absolute -bottom-0.5 -right-0.5 w-2 h-2 rounded-full bg-green-500 border border-white"></div>
      </div>
      <p class="font-medium">IP Address:</p>
      <p id="ip-address" class="font-normal transition-colors cursor-pointer hover:text-blue-700" title="Click to copy">Not Available</p>
    </div> -->

    <div class="absolute inset-0 bg-grid-slate-100 [mask-image:linear-gradient(0deg,white,rgba(255,255,255,0.6))] opacity-30 -z-10"></div>
    <div class="absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-blue-100 to-transparent -z-10"></div>
    <div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-white to-transparent -z-10"></div>
    <div class="flex flex-col lg:flex-row h-[85vh] lg:h-[calc(100vh-6rem)] justify-center items-center lg:relative lg:-top-[40px]">

      <div class="max-w-3xl pt-8 text-center lg:text-left lg:mr-8 lg:pt-10">
        <div class="text-center lg:text-left">
          <h1 class="mb-2 text-4xl font-extrabold leading-tight text-blue-900 lg:text-7xl">
            <span class="block text-blue-600 animate-fade-in-down">Welcome to</span>
            <span class="block text-blue-700 animate-fade-in-up">
              <span class="inline-block text-blue-800 animate-pulse">Bago City College</span>
            </span>
            <span class="block text-blue-600 animate-fade-in-right">Online Voting System</span>
          </h1>
        </div>
        <p class="pl-1 mb-8 text-lg text-gray-700 lg:mb-0 lg:text-2xl">
          Smart Voting for a Smarter Future
        </p>
        <div class="ml-1 font-normal text-gray-600">Developed by: VED System's Group</div>
      </div>

      <div class="mt-3 lg:mt-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" class="w-3/4 max-w-md m-auto lg:w-full lg:max-w-lg">
          <defs>
            <linearGradient id="blobGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#e9f6ff;stop-opacity:1" />
              <stop offset="100%" style="stop-color:#b0d2fb;stop-opacity:1" />
            </linearGradient>
          </defs>

          <!-- Blob background -->
          <path d="M0,150 C0,66.7 66.7,0 150,0 C233.3,0 300,66.7 300,150 C300,233.3 233.3,300 150,300 C66.7,300 0,233.3 0,150 Z" fill="url(#blobGradient)">
            <animate attributeName="d" dur="20s" repeatCount="indefinite" values="M0,150 C0,66.7 66.7,0 150,0 C233.3,0 300,66.7 300,150 C300,233.3 233.3,300 150,300 C66.7,300 0,233.3 0,150 Z;
                     M0,150 C0,93.8 93.8,0 150,0 C206.2,0 300,93.8 300,150 C300,206.2 206.2,300 150,300 C93.8,300 0,206.2 0,150 Z;
                     M0,150 C0,66.7 66.7,0 150,0 C233.3,0 300,66.7 300,150 C300,233.3 233.3,300 150,300 C66.7,300 0,233.3 0,150 Z" />
          </path>

          <!-- Digital Ballot Box -->
          <rect x="150" y="150" width="100" height="120" rx="10" fill="#3b82f6" />
          <rect x="160" y="160" width="80" height="100" rx="5" fill="white" />
          <path d="M170 180 L230 180 M170 200 L230 200 M170 220 L230 220" stroke="#3b82f6" stroke-width="2" />
          <rect x="190" y="130" width="20" height="40" fill="#3b82f6" />

          <!-- Voters -->
          <circle cx="100" cy="200" r="30" fill="#3b82f6" />
          <circle cx="100" cy="160" r="20" fill="#3b82f6" />
          <circle cx="300" cy="200" r="30" fill="#22c55e" />
          <circle cx="300" cy="160" r="20" fill="#22c55e" />

          <!-- Voting Paper -->
          <path d="M90 170 L110 170 L110 230 L90 230 Z" fill="white" stroke="#3b82f6" stroke-width="2">
            <animateTransform attributeName="transform" type="translate" values="0,0; 0,-10; 0,0" dur="2s" repeatCount="indefinite" />
          </path>
          <path d="M290 170 L310 170 L310 230 L290 230 Z" fill="white" stroke="#22c55e" stroke-width="2">
            <animateTransform attributeName="transform" type="translate" values="0,0; 0,-10; 0,0" dur="2s" repeatCount="indefinite" begin="1s" />
          </path>

          <!-- Digital Particles -->
          <g fill="#3b82f6" opacity="0.7">
            <circle cx="50" cy="50" r="3">
              <animate attributeName="cy" from="50" to="250" dur="3s" repeatCount="indefinite" />
            </circle>
            <circle cx="350" cy="250" r="2">
              <animate attributeName="cy" from="250" to="50" dur="4s" repeatCount="indefinite" />
            </circle>
            <circle cx="200" cy="50" r="4">
              <animate attributeName="cy" from="50" to="250" dur="3.5s" repeatCount="indefinite" />
            </circle>
          </g>

          <!-- Face Recognition Frame -->
          <rect x="260" y="70" width="80" height="80" rx="40" fill="none" stroke="#22c55e" stroke-width="2" stroke-dasharray="10 5">
            <animate attributeName="stroke-dashoffset" from="0" to="30" dur="2s" repeatCount="indefinite" />
          </rect>

          <!-- Binary Code -->
          <text x="30" y="100" font-family="monospace" font-size="14" fill="#3b82f6" opacity="0.5">
            <tspan x="30" dy="0">10110</tspan>
            <tspan x="30" dy="20">01001</tspan>
            <tspan x="30" dy="20">11010</tspan>
          </text>

          <!-- Checkmark -->
          <circle cx="50" cy="250" r="20" fill="#22c55e">
            <animate attributeName="r" values="20;22;20" dur="2s" repeatCount="indefinite" />
          </circle>
          <path d="M40 250 L50 260 L60 240" fill="none" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
            <animate attributeName="stroke-dasharray" values="0,30;30,0" dur="1s" begin="1s" fill="freeze" />
          </path>
        </svg>
      </div>

    </div>
  </main>

  <footer class="w-full p-6 text-sm text-blue-100 bg-gradient-to-r from-blue-700 to-blue-800 lg:fixed lg:bottom-0">
    <div class="flex flex-wrap justify-between max-w-6xl mx-auto">
      <div class="flex items-center mb-4 mr-6 lg:mb-0">
        <svg class="w-4 h-4 mr-2 text-blue-300" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
        </svg>
        <span class="font-light">0915 712 5272 | bagocitycollege.com</span>
      </div>

      <div class="flex items-center mb-4 mr-6 lg:mb-0">
        <svg class="w-4 h-4 mr-2 text-blue-300" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
        </svg>
        <span class="font-light">Brgy. Balingasag, Bago City, Negros Occidental</span>
      </div>

      <div class="flex items-center">
        <svg class="w-4 h-4 mr-2 text-blue-300" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z"></path>
        </svg>
        <a href="https://www.facebook.com/bagocitycollegeofficial" target="_blank" rel="noopener noreferrer" class="font-light transition-colors hover:text-white">
          Facebook: bagocitycollegeofficial
        </a>
      </div>
    </div>
  </footer>

  <!-- Login Modal -->
  <dialog id="login-modal" class="w-full px-2 pt-8 rounded-md shadow-lg lg:w-[400px] lg:px-7">
    <img src="/img/x.webp" id="login-modal-exit" alt="exit" class="absolute rounded-full w-7 top-3 right-3 opacity-70 hover:bg-blue-200">
    <img src="/img/bcc-logo.webp" alt="BCC Logo" class="w-1/3 m-auto">
    <form id="login-form" class="grid px-2 pb-10 rounded-md">
      <div class="grid">
        <label for="school-id" class="block mb-1 text-sm font-medium text-gray-900">Username</label class="font-semibold">
        <input type="text" id="school-id" placeholder="Enter your id number" class="py-1 pl-3 font-normal border border-gray-400 rounded-md focus:outline-blue-500">

        <div id="schoolIdErrorMessage" class="text-xs font-normal text-red-500 min-h-5"></div>
      </div>

      <div class="relative grid">
        <label for="password" class="block mb-1 text-sm font-medium text-gray-900">Password</label class="font-semibold ">
        <input type="password" id="password" placeholder="••••••••" class="py-1 pl-3 pr-10 font-normal border border-gray-400 rounded-md focus:outline-blue-500" autocomplete="off">
        <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 flex items-center pr-3">
          <svg id="show-icon" class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-.274 1.057-.742 2.057-1.375 2.957M15 12a3 3 0 01-6 0m6 0a3 3 0 01-6 0m6 0a3 3 0 01-6 0"></path>
          </svg>
          <svg id="hide-icon" class="hidden w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-5.523 0-10-4.477-10-10S6.477 0 12 0c1.657 0 3.22.402 4.625 1.125M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-.274 1.057-.742 2.057-1.375 2.957M15 12a3 3 0 01-6 0m6 0a3 3 0 01-6 0m6 0a3 3 0 01-6 0"></path>
          </svg>
        </button>
        <div id="passwordErrorMessage" class="text-xs font-normal text-red-500 min-h-5"></div>
      </div>

      <button type="submit" class="w-full mt-3 text-white bg-blue-600 hover:bg-blue-800 focus:outline-none font-medium rounded-lg text-sm px-5 py-2.5 text-center">Login to your account</button>
    </form>
  </dialog>

  <!-- Register device Modal -->
  <dialog id="registerDeviceModal" class="w-full max-w-md px-6 pt-8 pb-6 rounded-lg shadow-xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-blue-700">Register Device</h2>
      <button id="closeRegisterDevice" class="text-gray-400 transition-colors hover:text-gray-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>


    <form id="registerDeviceForm" class="space-y-4">
      <div>
        <label for="code-name" class="block mb-1 text-sm font-medium text-gray-700">Code name *</label>
        <input type="text" id="code-name" name="code-name" required class="w-full px-3 py-2 placeholder-gray-400 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Enter a unique code name">
        <div id="codeNameErrorMessage" class="mt-1 text-sm text-red-600 min-h-5"></div>
      </div>

      <button type="submit" class="flex justify-center w-full px-4 py-2 text-sm font-medium text-white transition-colors bg-blue-600 border border-transparent rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
        Generate UUID
      </button>
    </form>

  </dialog>

</body>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const menuToggle = document.getElementById('menu-toggle');
    const menuContent = document.getElementById('menu-content');

    menuToggle.addEventListener('click', function() {
      menuContent.classList.toggle('hidden');
      if (!menuContent.classList.contains('hidden')) {
        menuContent.style.top = `${menuToggle.offsetTop + menuToggle.offsetHeight}px`;
      }
    });

    // Hide menu when clicking outside
    document.addEventListener('click', function(event) {
      if (!menuToggle.contains(event.target) && !menuContent.contains(event.target)) {
        menuContent.classList.add('hidden');
      }
    });

    // Ensure menu is visible and properly positioned on larger screens
    window.addEventListener('resize', function() {
      if (window.innerWidth >= 1024) { // lg breakpoint
        menuContent.classList.remove('hidden');
        menuContent.style.top = '';
      } else {
        menuContent.classList.add('hidden');
      }
    });
  });
</script>

</html>