<body class="w-full font-bold h-dvh scroll-m-0 lg:overflow-hidden lg:h-screen bg-gradient-to-b from-blue-50 to-white">
  <header class="sticky top-0 z-10 w-full p-4 shadow-lg bg-gradient-to-r from-blue-700 to-blue-800 lg:px-8">
