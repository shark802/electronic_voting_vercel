<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Candidate</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/jquery-3.7.1.min.js"></script>
  <script src="/javascript/lib/sweetalert2@11.js"></script>
  <script src="/javascript/lib/socket.io.min.js" defer></script>
  <script type="module" src="/javascript/admin/candidate_manage.js" defer></script>
</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex overflow-hidden">

  <%- include("../partials/sidebar.ejs") %>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Candidate Manage</h1>
      <!-- <div class="flex items-center space-x-2">
        <button id="refresh-data" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Refresh data">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </button>
        <button id="user-menu" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="User menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </button>
      </div> -->
    </header>

    <div class="relative h-full mt-3 overflow-x-hidden rounded-lg lg:mb-2 bg-blue-50 no-scrollbar">

      <div class="flex items-center w-full gap-5 px-5 py-1 overflow-x-auto bg-blue-50 min-h-14 lg:px-7 lg:gap-7 flex-nowrap text-nowrap lg:min-h-16">
        <% positions.forEach(position => { %>
        <div id="position" class="py-1 font-semibold text-gray-400"><%= position %></div>
        <% }) %>
      </div>

      <div id="election-box" class="flex flex-wrap pb-24 gap-6 px-3 items-end overflow-x-auto overflow-y-auto max-h-[calc(100%-80px)] lg:px-7">
        <% if (elections.length < 1) { %>

        <!-- Display no election -->
        <section class=" mx-auto lg:w-[700px] bg-white rounded-lg shadow-sm p-6 text-center">
          <div class="flex justify-center mb-4">
            <img src="/img/empty-folder.webp" alt="Empty folder" class="object-contain w-24 h-24">
          </div>
          <h2 class="mb-4 text-2xl font-bold text-gray-800">No Active Elections</h2>
          <p class="mb-6 text-center text-gray-600">There are currently no scheduled elections or candidates to display.</p>
          <div class="flex justify-center">
            <a href="/admin/election/new" class="inline-block px-5 py-2 font-medium text-white transition-colors duration-200 ease-in-out bg-blue-500 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-50">
              Create Election
            </a>
          </div>
        </section>

        <% } else { %>

        <% elections.forEach(election => { %>
        <section id="election" class="w-full transition-colors border border-t-2 rounded-lg shadow bg-blue-50 min-w-fit h-fit min-h-16">
          <div class="px-8 py-5 bg-white rounded-t-md">
            <h2 class="mb-1 text-2xl font-bold text-blue-700"><%= election.election_name %></h2>
            <p id="election-id" class="flex items-center text-sm text-gray-500">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M10 2a1 1 0 00-1 1v1a1 1 0 002 0V3a1 1 0 00-1-1zM4 4h3a3 3 0 006 0h3a2 2 0 012 2v9a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2zm2.5 7a1.5 1.5 0 100-3 1.5 1.5 0 000 3zm2.45 4a2.5 2.5 0 10-4.9 0h4.9zM12 9a1 1 0 100 2h3a1 1 0 100-2h-3zm-1 4a1 1 0 011-1h2a1 1 0 110 2h-2a1 1 0 01-1-1z" clip-rule="evenodd"></path>
              </svg>
              <%= election.election_id %>
            </p>
          </div>

          <div id="candidates-display" class="p-1 pb-0 rounded-lg rounded-bl-lg rounded-br-lg h-fit no-scrollbar">

            <hr class="border-t border-gray-300 ">

            <div class=" no-scrollbar">
              <table class="w-full min-w-[700px]">
                <thead>
                  <tr class="text-white bg-blue-500">
                    <th class="px-2 py-2 text-xs font-medium lg:text-base lg:w-32">ID</th>
                    <th class="px-2 py-2 text-xs font-medium lg:text-base">Name</th>
                    <th class="px-2 py-2 text-xs font-medium lg:text-base">Party</th>
                    <th class="px-2 py-2 text-xs font-medium lg:text-base lg:w-40">Course</th>
                    <th class="px-2 py-2 text-xs font-medium lg:text-base lg:w-60">Created At</th>
                    <th class="px-2 py-2 text-xs font-medium lg:text-base">Status</th>
                    <th class="px-2 py-2 text-xs font-medium lg:text-base lg:w-36">Actions</th>
                  </tr>
                </thead>

                <tbody id="candidates-section" data-election-id="<%= election.election_id %>">
                  <!-- Table body content will be dynamically populated -->
                </tbody>
              </table>
            </div>

          </div>
        </section>
        <% }) %>
        <% } %>
      </div>

    </div>

  </main>

  <!-- Edit candidate Modal -->
  <dialog class="rounded-lg shadow-xl">
    <form id="editCandidateForm" class="w-full min-w-[500px] max-w-lg p-6 bg-white rounded-lg">
      <h2 class="mb-6 text-2xl font-bold text-gray-800">Edit Candidate</h2>

      <div class="flex items-center mb-6 space-x-4">
        <div class="relative w-24 h-24 overflow-hidden bg-gray-100 rounded-full">
          <img id="candidateImage" src="/img/default-profile.webp" alt="Candidate" class="object-cover w-full h-full">
          <label for="imageUpload" class="absolute inset-0 flex items-center justify-center transition-opacity bg-black bg-opacity-50 opacity-0 cursor-pointer hover:opacity-100">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </label>
          <input id="imageUpload" name="candidate_profile" type="file" accept="image/jpeg, image/png" class="hidden">
          <img id="previewImage" src="" alt="Image Preview" class="mt-2" style="display: none; max-width: 200px;">
        </div>
        <div>
          <div id="fullname" class="text-lg font-semibold text-gray-800">Name: </div>
          <div id="id-number" class="text-sm text-gray-600">ID: </div>
          <div id="course" class="text-sm text-gray-600">Course: </div>
        </div>
      </div>

      <div class="mb-4">
        <label class="block mb-2 text-sm font-medium text-gray-700" for="position">Position</label>
        <select id="selectPosition" name="position" class="w-full px-3 py-2 text-gray-700 bg-white border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Select a position</option>
          <% positions.forEach((value) => { %>
          <option value="<%= value %>"><%= value %></option>
          <% }) %>
        </select>
        <div id="positionErrorMessage" class="mt-1 text-sm text-red-500"></div>
      </div>

      <div class="mb-4">
        <label class="block mb-2 text-sm font-medium text-gray-700" for="party">Party</label>
        <input id="party" name="party" type="text" class="w-full px-3 py-2 text-gray-700 bg-white border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
        <div id="partyErrorMessage" class="mt-1 text-sm text-red-500"></div>
      </div>

      <div class="flex justify-end space-x-2">
        <button id="closeModal" formmethod="dialog" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-200 rounded-md hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-gray-400">
          Cancel
        </button>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-500 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-400">
          Save Changes
        </button>
      </div>
    </form>
  </dialog>

  <script>
    document.getElementById('imageUpload').addEventListener('change', function(event) {
      const file = event.target.files[0]; // Get the selected file
      if (file) {
        const reader = new FileReader(); // Create a FileReader to read the file
        reader.onload = function(e) {
          const previewImage = document.getElementById('previewImage');
          previewImage.src = e.target.result; // Set the image source to the file data
          previewImage.style.display = 'block'; // Show the image
        };
        reader.readAsDataURL(file); // Read the file as a data URL
      }
    });
  </script>

</body>

</html>