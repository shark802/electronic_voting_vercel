<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Election Analytics</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/jquery-3.7.1.min.js"></script>
  <script src="/javascript/lib/socket.io.min.js" defer></script>
  <script src="/javascript/lib/sweetalert2@11.js"></script>
  <script src="/javascript/lib/chart.umd.min.js"></script>
  <script type="module" src="/javascript/admin/dashboard_analytics.js" defer></script>
</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex overflow-hidden">

  <%- include("../partials/sidebar.ejs") %>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Past Election Analytics</h1>
      <!-- <div class="flex items-center space-x-2">
        <button id="refresh-data" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Refresh data">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </button>
        <button id="user-menu" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="User menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </button>
      </div> -->
    </header>

    <div class="relative h-screen p-2 pb-12 mt-3 overflow-x-hidden overflow-y-auto bg-blue-100 rounded-lg lg:px-5 lg:p-5 lg:mb-2">

      <div class="flex flex-col lg:flex-row">
        <div class="w-full lg:w-[85%] lg:float-left bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 px-2 lg:mr-2">
          <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-800 lg:text-2xl">Voter Engagement Trends</h2>
            <p class="mt-1 text-sm text-gray-600">Historical voter participation rates across all past elections, showing turnout percentages over time.</p>
          </div>
          <!-- Chart Container -->
          <canvas id="voter-engagement-trends" class="min-w-full lg:max-h-[360px] mb-1"></canvas>
        </div>

        <!-- Stats Container -->
        <div class="flex flex-row lg:flex-col pt-3 lg:pt-0 grow-1 lg:gap-3 lg:w-[15%]">

          <div class="flex-1 p-2 mx-2 transition-shadow duration-300 bg-white border shadow-md grow rounded-xl hover:shadow-lg">
            <p class="mb-3 text-xs font-semibold text-center text-gray-700 lg:text-sm ">Highest Turnout</p>
            <div class="relative w-20 h-20 mx-auto">
              <canvas id="highest-turnout-chart"></canvas>
              <div class="absolute inset-0 flex items-center justify-center">
                <span id="highest-turnout-text" class="text-lg font-bold text-green-500"></span>
              </div>
            </div>
          </div>

          <div class="flex-1 p-2 mx-2 transition-shadow duration-300 bg-white shadow-md rounded-xl hover:shadow-lg borderg">
            <p class="mb-3 text-xs font-semibold text-center text-gray-700 lg:text-sm ">Lowest Turnout</p>
            <div class="relative w-20 h-20 mx-auto">
              <canvas id="lowest-turnout-chart"></canvas>
              <div class="absolute inset-0 flex items-center justify-center">
                <span id="lowest-turnout-text" class="text-lg font-bold text-red-500"></span>
              </div>
            </div>
          </div>

          <div class="flex-1 p-2 mx-2 transition-shadow duration-300 bg-white shadow-md rounded-xl hover:shadow-lg borderg">
            <p class="mb-3 text-xs font-semibold text-center text-gray-700 lg:text-sm ">Average Turnout</p>
            <div class="relative w-20 h-20 mx-auto">
              <canvas id="average-turnout-chart"></canvas>
              <div class="absolute inset-0 flex items-center justify-center">
                <span id="average-turnout-text" class="text-lg font-bold text-blue-600"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-4 mt-4 lg:flex-row">
        <div class="pb-0 transition-shadow duration-300 bg-white shadow-sm rounded-xl hover:shadow-lg min-h-fit lg:w-1/2 lg:p-2 lg:pt-0">
          <div class="px-5 py-2 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-800 lg:text-2xl">Engagement Per Year Level</h2>
            <p class="mt-1 text-sm text-gray-600">Comparison of voter participation rates across different year levels, showing which groups are most engaged.</p>
          </div>
          <canvas id="engagement-per-year-level" class="w-full h-full max-h-[280px] "></canvas>
        </div>

        <div class="pb-0 transition-shadow duration-300 bg-white shadow-md rounded-xl hover:shadow-lg min-h-fit lg:w-1/2 lg:p-2 lg:pt-0">
          <div class="px-5 py-2 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-800 lg:text-2xl">Engagement Per Department</h2>
            <p class="mt-1 text-sm text-gray-600">Analysis of voter turnout by academic department, highlighting departmental participation differences.</p>
          </div>
          <canvas id="engagement-per-department" class="w-full h-full max-h-[280px]"></canvas>
        </div>
      </div>

      <div class="flex flex-col gap-4 mt-4 lg:mt-10 lg:flex-row">
        <div class="pb-0 transition-shadow duration-300 bg-white shadow-sm rounded-xl hover:shadow-lg min-h-fit lg:w-1/2 lg:p-2 lg:pt-0">
          <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-800 lg:text-2xl">On-Campus Voter Participation</h2>
            <p class="mt-1 text-sm text-gray-600">Trends in physical polling station usage over time, showing how on-campus voting patterns have evolved.</p>
          </div>
          <canvas id="onsite-engagement" class="w-full h-full max-h-[230px]"></canvas>
        </div>

        <div class="pb-0 transition-shadow duration-300 bg-white shadow-md rounded-xl hover:shadow-lg min-h-fit lg:w-1/2 lg:p-2 lg:pt-0">
          <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-800 lg:text-2xl">Online Voter Participation</h2>
            <p class="mt-1 text-sm text-gray-600">Analysis of remote voting trends, showing the adoption and usage patterns of the online voting platform.</p>
          </div>
          <canvas id="online-engagement" class="w-full h-full max-h-[230px]"></canvas>
        </div>
      </div>

    </div>

  </main>

</body>

</html>