<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Election Tally</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/jquery-3.7.1.min.js"></script>
  <script src="/javascript/lib/socket.io.min.js" defer></script>
  <script src="/javascript/lib/sweetalert2@11.js"></script>
  <script src="/javascript/lib/chart.umd.min.js"></script>
  <script type="module" src="/javascript/admin/dashboard_vote_tally.js" defer></script>
</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex overflow-hidden">

  <%- include("../partials/sidebar.ejs") %>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Election Tally</h1>
    </header>

    <div id="vote-tally-container" class="relative h-screen p-2 mt-3 overflow-x-hidden overflow-y-auto rounded-lg bg-blue-50 lg:gap-3 lg:px-5 lg:p-5 lg:mb-2">

      <% if (elections && elections.length === 0) { %>

      <section class="max-w-2xl mx-auto mt-5 overflow-hidden bg-white rounded-lg shadow-md">
        <div class="p-8 text-center w-[90%] m-auto">
          <img src="/img/empty-folder.webp" alt="Empty folder" class="w-24 h-24 mx-auto mb-6 opacity-75">
          <h1 class="mb-4 text-2xl font-bold text-gray-800">No Elections Scheduled</h1>
          <p class="mb-6 text-gray-600">It seems there are no elections scheduled at the moment. Would you like to create a new one?</p>
          <a href="/admin/election/new" class="inline-block">
            <button class="px-6 py-3 font-semibold text-white transition duration-300 ease-in-out transform bg-blue-500 rounded-lg shadow-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-75 hover:-translate-y-1">
              <svg class="inline-block w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              Create New Election
            </button>
          </a>
        </div>
      </section>

      <% } else { %>

      <% elections.forEach(election => { %>

      <section id="election-section" data-election-id="<%= election.election_id %>" class="pb-6 mb-12 bg-white border border-blue-200 shadow-sm rounded-xl">
        <input id="date-end" type="hidden" value="<%= election.date_end %>">
        <input id="time-end" type="hidden" value="<%= election.time_end %>">

        <div class="flex items-center justify-between p-5 text-white rounded-t-xl bg-gradient-to-r from-blue-600 to-blue-700">
          <div>
            <h2 class="text-xl font-bold lg:text-2xl"><%= election.election_name %></h2>
            <p id="election-id" class="mt-1 text-sm text-blue-100 opacity-80"><%= election.election_id %></p>
          </div>
          <div class="flex items-center space-x-2">
            <span id="election-status" class="px-3 py-1 text-xs font-medium bg-blue-500 rounded-full shadow-inner">
              <%= election.is_active ? 'Active' : 'Inactive' %>
            </span>
          </div>
        </div>

        <div class="flex flex-col w-full gap-6 p-2 gap-x-4 lg:flex-row lg:flex-wrap lg:justify-between lg:p-6">
          <% 
          candidatePosition.forEach(position => { 
            const candidatesPerPosition = candidates.filter(candidate => candidate.position === position && candidate.election_id === election.election_id);
            if (candidatesPerPosition.length > 0) {
              if (position === 'SENATOR') { 
          %>

          <div data-position="<%= position %>" id="position-container" class="w-full overflow-hidden transition-all duration-300 bg-white border border-gray-100 shadow-md rounded-xl hover:shadow-lg">
            <div class="flex flex-col">
              <!-- Header Section with modern gradient and spacing -->
              <div class="flex items-center justify-between p-6 border-b bg-gradient-to-r from-blue-50 via-blue-50 to-indigo-50 border-blue-100/50">
                <div class="flex flex-col gap-1">
                  <h3 class="text-xl font-bold tracking-tight text-gray-800">
                    <%= position.replace('_', ' ') %>
                  </h3>
                </div>

                <!-- Modern pill badge with subtle shadow -->
                <span class="px-4 py-1.5 text-sm font-medium text-blue-700 bg-blue-50 rounded-full shadow-sm border border-blue-100/50">
                  <%= candidatesPerPosition.length %> candidate<%= candidatesPerPosition.length > 1 ? 's' : '' %>
                </span>
              </div>


              <div class="flex flex-col w-full gap-4 p-4 lg:flex-row lg:flex-wrap lg:justify-between lg:p-6">
                <% programs.forEach(program => { 
                  const senatorCandidatesPerProgram = candidates.filter(candidate => candidate.position === 'SENATOR' && candidate.election_id === election.election_id);
                  if (senatorCandidatesPerProgram.length > 0) { 
              %>
                <div id="senator-by-program" class="w-full overflow-hidden bg-white border border-gray-100 rounded-lg shadow-sm transition-all duration-300 hover:shadow-md lg:w-[49%]">
                  <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-gray-100">
                    <div class="flex items-center gap-2">
                      <div class="flex items-center justify-center w-6 h-6 text-white bg-blue-500 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                          <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                        </svg>
                      </div>
                      <span class="font-medium text-gray-800"><%= program %></span>
                    </div>
                  </div>
                  <div class="p-4">
                    <canvas id="<%= program %>" class="w-full min-h-[300px] bg-white rounded-md"></canvas>
                  </div>
                </div>
                <% } }) %>
              </div>
            </div>

            <% } else { %>

            <div data-position="<%= position %>" id="position-container" class="overflow-hidden bg-white rounded-2xl shadow-lg transition-all duration-300 hover:shadow-xl border border-gray-100/50 lg:w-[49%]">
              <div class="flex flex-col">
                <!-- Header Section with improved gradient and spacing -->
                <div class="flex items-center justify-between p-6 border-b bg-gradient-to-r from-blue-50 via-blue-50 to-indigo-50 border-blue-100/50">
                  <div class="flex flex-col gap-1">
                    <h3 class="text-xl font-bold tracking-tight text-gray-800">
                      <%= position.replace('_', ' ') %>
                    </h3>
                  </div>

                  <!-- Modern pill badge with subtle shadow -->
                  <span class="px-4 py-1.5 text-sm font-medium text-blue-700 bg-blue-50 rounded-full shadow-sm border border-blue-100/50">
                    <%= candidatesPerPosition.length %> candidate<%= candidatesPerPosition.length > 1 ? 's' : '' %>
                  </span>
                </div>

                <!-- Content Section with improved spacing -->
                <div class="p-6">
                  <!-- Added a subtle border and shadow to the canvas -->
                  <div class="overflow-hidden border border-gray-100 shadow-sm rounded-xl">
                    <canvas id="<%= position %>" class="w-full min-h-[300px] bg-white"></canvas>
                  </div>

                </div>
              </div>
            </div>

            <% } } }) %>
          </div>
      </section>

      <% }) %>

      <% } %>

    </div>
  </main>
</body>

</html>