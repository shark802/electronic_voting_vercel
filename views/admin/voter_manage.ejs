<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Voter Activity</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/jquery-3.7.1.min.js"></script>
  <script src="/javascript/lib/sweetalert2@11.js"></script>
  <script src="/javascript/lib/socket.io.min.js" defer></script>
  <script type="module" src="/javascript/admin/voter_manage.js" defer></script>
</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex">

  <%- include("../partials/sidebar.ejs") %>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Voter Activity</h1>
      <!-- <div class="flex items-center space-x-2">
        <button id="refresh-data" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Refresh data">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </button>
        <button id="user-menu" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="User menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </button>
      </div> -->
    </header>

    <div class="relative h-full mt-3 overflow-hidden overflow-x-hidden overflow-y-auto rounded-lg lg:mb-3 bg-blue-50 no-scrollbar">

      <div class="lg:p-4 flex items-center justify-between p-2 pb-4 bg-white lg:h-[70px]">

        <form action="/admin/voter/manage" method="get" id="filter-voted-users-form" class="flex flex-col justify-between w-full gap-2 lg:flex-row lg:gap-4">
          <div class="flex items-center flex-grow gap-2">
            <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
            </svg>
            <label for="filter-by-election" class="hidden text-sm font-medium text-gray-500 lg:inline-block">Filter by recent election: </label>
            <select name="election" id="filter-by-election" class="w-full py-1 text-xs border border-gray-300 rounded-md lg:text-sm lg:py-2 min-w-32 lg:w-fit focus:outline-none focus:ring-2 focus:ring-blue-500 lg:px-2">
              <option value="">All Elections</option>
              <% if (availableElections && availableElections.length > 0) {
                   availableElections.forEach(election => { %>
              <option value="<%= election.election_id %>"><%= election.election_name %></option>
              <% })} %>
            </select>
          </div>

          <div class="relative flex items-center">
            <input type="search" name="user_id" id="search-user" placeholder="Search by ID number" class="w-full px-4 py-2 pr-10 text-sm border border-gray-300 rounded-md lg:w-64 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <button type="submit" class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-500 hover:text-blue-500 focus:outline-none">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>

      <div class="w-full lg:px-3 h-[calc(100%-87px)] overflow-auto">

        <div class="overflow-x-auto">
          <table class="w-full border-collapse min-w-[640px]">
            <thead>
              <tr class="text-white bg-blue-600">
                <th class="px-4 py-3 text-xs font-medium text-left lg:text-sm">#</th>
                <th class="px-4 py-3 text-xs font-medium text-left lg:text-sm">Name</th>
                <th class="px-4 py-3 text-xs font-medium text-left lg:text-sm">ID</th>
                <th class="px-4 py-3 text-xs font-medium text-left lg:text-sm">Course</th>
                <th class="px-4 py-3 text-xs font-medium text-left lg:text-sm">Election</th>
                <th class="px-4 py-3 text-xs font-medium text-left lg:text-sm">Election ID</th>
                <th class="px-4 py-3 text-xs font-medium text-left lg:text-sm">Voted At</th>
              </tr>
            </thead>

            <tbody>
              <% if(votedUsers && votedUsers.length > 0) {
                   votedUsers.forEach((voter, index )=> {
                     let candidateAddedAt = new Date(voter.time_casted);
                     const options = {
                       year: 'numeric',
                       month: 'long',
                       day: 'numeric',
                       hour: '2-digit',
                       minute: '2-digit',
                     };
                     const timeVoted = candidateAddedAt.toLocaleString('en-US', options);

              %>
              <tr class="transition-colors duration-200 bg-white border-b border-gray-200 hover:bg-blue-100">
                <td class="px-4 py-2 text-xs font-medium text-gray-600">
                  <span class=""><%= (currentPage - 1) * limit + index + 1 %></span>
                </td>

                <td class="px-4 py-2 text-xs font-medium text-gray-600">
                  <span class="font-bold"><%= voter.lastname %></span>, <%= voter.firstname %>
                </td>
                <td class="px-4 py-2 text-xs text-gray-600" title="ID Number">
                  <%= voter.id_number %>
                </td>
                <td class="px-4 py-2 text-xs text-gray-600" title="Course and Year Level">
                  <%= voter.course %> - <%= voter.year_level %> <%= voter.section %>
                </td>
                <td class="px-4 py-2 text-xs text-gray-600" title="Election Name">
                  <span class="tooltip" data-tooltip="Election Name: <%= voter.election_name %>">
                    <%= voter.election_name %>
                  </span>
                </td>
                <td class="px-4 py-2 text-xs text-gray-600" title="Election ID">
                  <%= voter.election_id %>
                </td>
                <td class="px-4 py-2 text-xs text-gray-600" title="Time Voted">
                  <%= timeVoted %>
                </td>
              </tr>
              <% });
                 } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination Controls -->
        <div class="flex items-center justify-between mt-6  <%= Number(totalUsers) < 1 ? 'invisible' : 'block'  %> ">
          <p class="mr-4 text-sm text-gray-600">
            Showing <%= (currentPage - 1) * limit + 1 %> to <%= Math.min(currentPage * limit, Number(totalUsers)) %> of <%= Number(totalUsers)%> entries
          </p>
          <div class="flex items-center space-x-2">
            <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>&election=<%= election %>&user_id=<%= user_id %>" class="px-3 py-1 text-sm font-medium text-white transition-colors duration-300 bg-blue-500 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50">Previous</a>
            <% } %>
            <% if (currentPage * limit < Number(totalUsers)) { %>
            <a href="?page=<%= currentPage + 1 %>&election=<%= election %>&user_id=<%= user_id %>" class="px-3 py-1 text-sm font-medium text-white transition-colors duration-300 bg-blue-500 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-opacity-50">Next</a>
            <% } %>
          </div>
        </div>

        <%
        if (votedUsers.length <= 0) {
        %>

        <div class="p-6">
          <div class="max-w-lg mx-auto overflow-hidden bg-white rounded-lg shadow-md">
            <div class="p-8 bg-white border-b border-blue-100">
              <img src="/img/empty-folder.webp" alt="Empty folder" class="w-24 h-24 mx-auto mb-6 opacity-75">

              <h2 class="mb-3 text-2xl font-bold text-center text-gray-800">No Voter Records Found</h2>
              <p class="mb-4 text-center text-gray-600">We couldn't find any voter records matching your search criteria.</p>
            </div>
          </div>
        </div>

        <%
        }
        %>

      </div>

    </div>

  </main>

</body>

</html>