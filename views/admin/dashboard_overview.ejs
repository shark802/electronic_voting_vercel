<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Election Overview</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/jquery-3.7.1.min.js" defer></script>
  <script src="/javascript/lib/socket.io.min.js" defer></script>
  <script src="/javascript/lib/sweetalert2@11.js" defer></script>
  <script type="module" src="/javascript/admin/dashboard_overview.js" defer></script>

  <style>
    #manage-population-modal::backdrop {
      background-color: rgba(0, 0, 0, 0.3);
    }

    .pulse-icon {
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0% {
        transform: scale(1);
      }

      50% {
        transform: scale(1.1);
      }

      100% {
        transform: scale(1);
      }
    }
  </style>
</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex overflow-hidden">

  <%- include("../partials/sidebar.ejs") %>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Election Overview</h1>
      <!-- <div class="flex items-center space-x-2">
        <button id="refresh-data" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Refresh data">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </button>
        <button id="user-menu" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="User menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </button>
      </div> -->
    </header>

    <div id="overview-container" class="relative h-full mt-3 overflow-hidden overflow-x-hidden overflow-y-auto rounded-lg lg:p-5 lg:pt-3 lg:mb-2 bg-blue-50 no-scrollbar">

      <% if (elections && elections.length > 0) { 
        elections.forEach(election => { %>

      <section id="election-section" data-election-id="<%= election.election_id %>" class="pb-3 mb-5 overflow-hidden bg-white shadow-lg rounded-xl">
        <input id="date-end" type="hidden" value="<%= election.date_end %>">
        <input id="time-end" type="hidden" value="<%= election.time_end %>">

        <!-- Election Header with Modern Design -->
        <div class="relative p-4 text-white bg-gradient-to-r from-blue-700 via-blue-600 to-blue-700">
          <!-- Decorative Elements -->
          <div class="absolute top-0 right-0 w-64 h-64 -mt-32 -mr-32 rounded-full bg-white/5"></div>
          <div class="absolute bottom-0 left-0 w-32 h-32 -mb-16 -ml-16 rounded-full bg-white/5"></div>

          <div class="relative flex items-center justify-between">
            <div class="flex items-center">
              <div class="flex items-center justify-center w-12 h-12 mr-4 rounded-lg bg-white/10 backdrop-blur-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3v18h18" />
                  <path d="M3 12h2l2-4 3 8 4-12 3 8 2-4h2" />
                  <circle cx="9" cy="16" r="1" />
                  <circle cx="16" cy="8" r="1" />
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-bold lg:text-2xl"><%= election.election_name %></h2>
                <p id="election-id" class="text-sm text-blue-100 opacity-80"><%= election.election_id %></p>
              </div>
            </div>
            <div class="flex items-center space-x-3">
              <span id="election-status" class="px-4 py-1.5 text-xs font-medium rounded-full <%= election.is_active ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-800' %> shadow-md">
                <%= election.is_active ? 'Active' : 'Inactive' %>
              </span>

              <!-- View Results Button - Only show when election has ended -->
              <% 
                const currentDate = new Date();
                const electionEndDate = new Date(election.date_end + ' ' + election.time_end);
                const hasElectionEnded = currentDate > electionEndDate;
              %>
              <button id="result-button" class="hidden">
                <a href="/admin/election/result/<%= election.election_id %>" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white transition-all duration-200 rounded-lg bg-white/20 backdrop-blur-sm hover:bg-white/30 focus:outline-none focus:ring-2 focus:ring-white/50 group">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2 transition-transform duration-200 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                  View Results
                </a>
              </button>

              <button id="manage" class="hidden p-2 text-blue-100 transition-colors duration-200 rounded-full hover:text-white focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 pulse-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 16l2 2 4-4" />
                </svg>
                <span class="sr-only">Close Election</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Stats Cards - Modern Design with Original Colors -->
        <div class="flex flex-grow w-full gap-3 px-4 pt-4 pb-1">
          <!-- Total Students Card -->
          <div class="w-1/3 overflow-hidden shadow-md rounded-xl group">
            <div class="p-3 text-white bg-gradient-to-br from-blue-600 to-blue-700 lg:p-4">
              <div class="flex items-center">
                <div class="flex items-center justify-center w-10 h-10 mr-3 rounded-lg bg-white/20 backdrop-blur-sm">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-medium tracking-wider text-blue-100 uppercase">Total Students</p>
                  <div class="flex items-baseline">
                    <p id="total-population" class="text-2xl font-bold transition-all duration-300 origin-left group-hover:scale-110"><%= election.total_populations || "N/A" %></p>
                    <p id="total-population-percentage" class="ml-2 text-blue-200">100.00%</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Voted Card -->
          <div class="w-1/3 overflow-hidden shadow-md rounded-xl group">
            <div class="p-3 text-white bg-gradient-to-br from-green-600 to-green-700 lg:p-4">
              <div class="flex items-center">
                <div class="flex items-center justify-center w-10 h-10 mr-3 rounded-lg bg-white/20 backdrop-blur-sm">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-medium tracking-wider text-green-100 uppercase">Voted</p>
                  <div class="flex items-baseline">
                    <p id="total-voted" class="text-2xl font-bold transition-all duration-300 origin-left group-hover:scale-110">0</p>
                    <p id="total-voted-percentage" class="ml-2 text-green-200">(0.00%)</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Not Voted Card -->
          <div class="w-1/3 overflow-hidden shadow-md rounded-xl group">
            <div class="p-3 text-white bg-gradient-to-br from-red-600 to-red-700 lg:p-4">
              <div class="flex items-center">
                <div class="flex items-center justify-center w-10 h-10 mr-3 rounded-lg bg-white/20 backdrop-blur-sm">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" strokeLinejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-medium tracking-wider text-red-100 uppercase">Not Voted</p>
                  <div class="flex items-baseline">
                    <p id="number-of-not-voted" class="text-2xl font-bold transition-all duration-300 origin-left group-hover:scale-110">N/A</p>
                    <p id="total-not-voted-percentage" class="ml-2 text-red-200">(N/A)</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Department Statistics - Modern Design -->
        <div class="grid gap-2 px-4 py-2">
          <% populationPerProgram.filter(program => program.election_id === election.election_id).forEach(course => { %>
          <div id="program" class="w-full overflow-hidden transition-all duration-200 bg-white border border-gray-200 rounded-lg shadow-sm hover:border-blue-200 hover:shadow group">
            <div class="flex flex-col sm:flex-row">
              <!-- Department Code -->
              <div id="program-code" data-program-code="<%= course.program_code %>" class="flex items-center justify-center p-3 text-white bg-blue-600 sm:w-[20%]">
                <div class="text-center">
                  <p class="text-xl font-bold"><%= course.program_code %></p>
                  <p class="text-xs tracking-wider uppercase opacity-80">Department</p>
                </div>
              </div>

              <!-- Department Stats with Icon Buttons -->
              <div class="flex flex-grow w-full gap-3 p-3 bg-gray-50">
                <!-- Total Voters -->
                <div class="flex-1 p-2 text-center bg-white rounded-lg">
                  <p id="program-population" class="text-xl font-bold text-gray-800"><%= course.program_population === 0 ? 'N/A' : course.program_population %></p>
                  <p class="text-xs font-medium text-gray-500">Total Voters</p>
                </div>

                <!-- Voted with Icon Button and Sliding Animation -->
                <div class="relative flex-1 p-2 text-center bg-white rounded-lg">
                  <p id="departmentTotalVotes" class="text-xl font-bold text-green-600">0</p>
                  <p class="text-xs font-medium text-gray-500">Voted</p>

                  <!-- Voted Report Button with Sliding Animation -->
                  <div class="absolute top-1 right-1">
                    <a href="/report/voter/<%= election.election_id %>?voteStatus=voted&department=<%= course.program_code %>" class="relative inline-flex items-center">
                      <div class="relative flex items-center">
                        <!-- Sliding Text Container - Now positioned to overlap with the button -->
                        <div class="absolute top-0 right-0 w-0 overflow-hidden transition-all duration-300 ease-out whitespace-nowrap group-hover:w-32">
                          <span class="px-2 py-1 text-xs font-medium text-green-600 transition-colors bg-green-100 rounded-l-full">
                            View Report
                          </span>
                        </div>

                        <!-- Report Icon - Now has rounded-r-full when text is shown -->
                        <button class="relative z-10 p-1 text-green-600 transition-colors bg-green-100 rounded-full group-hover:rounded-l-none group-hover:rounded-r-full">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                          </svg>
                        </button>
                      </div>
                    </a>
                  </div>
                </div>

                <!-- Not Voted with Icon Button and Sliding Animation -->
                <div class="relative flex-1 p-2 text-center bg-white rounded-lg">
                  <p id="departmentNumberOfNotVoted" class="text-xl font-bold text-red-600"><%= course.program_population === 0 ? 'N/A' : course.program_population %></p>
                  <p class="text-xs font-medium text-gray-500">Not Voted</p>

                  <!-- Not Voted Report Button with Sliding Animation -->
                  <div class="absolute top-1 right-1">
                    <a href="/report/voter/<%= election.election_id %>?voteStatus=not-voted&department=<%= course.program_code %>" class="relative inline-flex items-center">
                      <div class="relative flex items-center">
                        <!-- Sliding Text Container - Now positioned to overlap with the button -->
                        <div class="absolute top-0 right-0 w-0 overflow-hidden transition-all duration-300 ease-out whitespace-nowrap group-hover:w-32">
                          <span class="px-2 py-1 text-xs font-medium text-red-600 transition-colors bg-red-100 rounded-l-full">
                            View Report
                          </span>
                        </div>

                        <!-- Report Icon - Now has rounded-r-full when text is shown -->
                        <button class="relative z-10 p-1 text-red-600 transition-colors bg-red-100 rounded-full group-hover:rounded-l-none group-hover:rounded-r-full">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                          </svg>
                        </button>
                      </div>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>

      </section>

      <% }) } else { %>

      <!-- Empty State - Modern Design -->
      <section class="max-w-2xl mx-auto mt-5 overflow-hidden bg-white shadow-md rounded-xl">
        <div class="p-8 text-center">
          <div class="flex items-center justify-center w-20 h-20 mx-auto mb-6 rounded-full bg-blue-50">
            <svg class="w-10 h-10 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h1 class="mb-4 text-2xl font-bold text-gray-800">No Elections Scheduled</h1>
          <p class="mb-6 text-gray-600">It seems there are no elections scheduled at the moment. Would you like to create a new one?</p>
          <a href="/admin/election/new" class="inline-block">
            <button class="px-6 py-3 font-semibold text-white transition duration-300 ease-in-out transform rounded-lg shadow-md bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-opacity-75 hover:-translate-y-1">
              <svg class="inline-block w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              Create New Election
            </button>
          </a>
        </div>
      </section>

      <% } %>

    </div>


  </main>

  <dialog id="close-election" class="w-[95%] max-w-[500px] p-0 rounded-lg shadow-xl bg-white overflow-hidden">
    <input type="hidden" id="election-id">
    <div class="p-6 bg-yellow-100 border-b border-gray-200">
      <div class="flex items-center space-x-4">
        <div class="p-3 bg-yellow-500 rounded-full">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-yellow-600">Election Concluded</h2>
          <p class="mt-1 text-sm text-yellow-600">
            Ended at <underline class="font-medium underline underline-offset-2"></underline>
          </p>
        </div>
      </div>
    </div>

    <div class="p-6">
      <p class="mb-6 text-gray-700">
        All results have been recorded. No further changes can be made.
        Please review the final outcomes and ensure proper data archiving.
      </p>

      <div class="flex justify-end space-x-4">
        <button id="exit-close-election-modal" class="px-4 py-2 text-gray-600 transition-colors duration-200 hover:text-gray-800">
          Cancel
        </button>
        <button id="close-election-button" class="px-4 py-2 text-white transition-colors duration-200 bg-yellow-500 rounded-md hover:bg-yellow-600 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-opacity-50">
          Close Election
        </button>
      </div>
    </div>
  </dialog>

</body>

</html>