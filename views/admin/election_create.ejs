<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Election</title>

  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/jquery-3.7.1.min.js"></script>
  <script src="/javascript/lib/sweetalert2@11.js"></script>
  <script src="/javascript/lib/socket.io.min.js" defer></script>
  <script type="module" src="/javascript/admin/election_create.js" defer></script>

</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex overflow-hidden">

  <%- include("../partials/sidebar.ejs") %>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Create New Election</h1>
      <!-- <div class="flex items-center space-x-2">
        <button id="refresh-data" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Refresh data">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </button>
        <button id="user-menu" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="User menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </button>
      </div> -->
    </header>

    <div class="relative flex justify-center h-full mt-3 mb-2 overflow-hidden overflow-x-hidden overflow-y-auto rounded-lg bg-blue-50 no-scrollbar">

      <div class="self-center m-auto absolute py-6 bg-white rounded-xl lg:w-[600px] min-h-auto max-w-4/5 w-[90%] shadow-lg border border-gray-200">
        <form id="create_election_form" class="px-6 py-4 space-y-5">


          <!-- Election Name -->
          <div class="space-y-2">
            <label for="election_name" class="block text-sm font-medium text-gray-700">
              Election Name
              <span class="text-red-500">*</span>
            </label>
            <input id="election_name" type="text" class="w-full px-3 py-2 text-sm transition-all border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 placeholder:text-gray-400" placeholder="Enter election name">
            <div id="election_name_error_message" class="text-xs text-red-500"></div>
          </div>

          <!-- Election Period -->
          <div class="space-y-3">
            <div class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <h3 class="text-sm font-medium text-gray-800">Election Period</h3>
            </div>

            <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
              <!-- Start Date & Time -->
              <div class="p-3 space-y-3 rounded-lg bg-gray-50">
                <h4 class="text-sm font-medium text-gray-700">Start Date & Time</h4>
                <div class="space-y-2">
                  <div class="space-y-1">
                    <label for="date_start" class="block text-sm font-medium text-gray-600">
                      Date
                      <span class="text-red-500">*</span>
                    </label>
                    <input id="date_start" type="date" class="w-full px-3 py-2 text-sm transition-all border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <div id="startdate_error_message" class="text-xs text-red-500"></div>
                  </div>
                  <div class="space-y-1">
                    <label for="time_start" class="block text-sm font-medium text-gray-600">
                      Time
                      <span class="text-red-500">*</span>
                    </label>
                    <input id="time_start" type="time" class="w-full px-3 py-2 text-sm transition-all border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <div id="starttime_error_message" class="text-xs text-red-500"></div>
                  </div>
                </div>
              </div>

              <!-- End Date & Time -->
              <div class="p-3 space-y-3 rounded-lg bg-gray-50">
                <h4 class="text-sm font-medium text-gray-700">End Date & Time</h4>
                <div class="space-y-2">
                  <div class="space-y-1">
                    <label for="date_end" class="block text-sm font-medium text-gray-600">
                      Date
                      <span class="text-red-500">*</span>
                    </label>
                    <input id="date_end" type="date" class="w-full px-3 py-2 text-sm transition-all border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <div id="enddate_error_message" class="text-xs text-red-500"></div>
                  </div>
                  <div class="space-y-1">
                    <label for="time_end" class="block text-sm font-medium text-gray-600">
                      Time
                      <span class="text-red-500">*</span>
                    </label>
                    <input id="time_end" type="time" class="w-full px-3 py-2 text-sm transition-all border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <div id="endtime_error_message" class="text-xs text-red-500"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="pt-4">
            <button type="submit" class="w-full px-4 py-2.5 text-sm font-medium text-white transition-all bg-blue-600 rounded-lg shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
              Create Election
            </button>
          </div>
        </form>
      </div>

    </div>
  </main>

</body>

</html>