  <script src="/javascript/lib/sweetalert2@11.js"></script>
  <script src="/javascript/lib/socket.io.min.js"></script>
  <script type="module" src="/javascript/admin/department_manage.js" defer></script>

  <style>
    #decline-request-modal::backdrop,
    #accept-request-modal::backdrop {
      background-color: rgba(0, 0, 0, 0.3);
    }
  </style>
</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex">

  <%- include("../partials/sidebar.ejs") %>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Manage Departments</h1>
      <!-- <div class="flex items-center space-x-2">
        <button id="refresh-data" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Refresh data">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </button>
        <button id="user-menu" class="p-2 text-white transition-colors duration-200 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="User menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </button>
      </div> -->
    </header>

    <div class="relative flex flex-col items-center h-full px-3 mt-3 overflow-hidden overflow-x-hidden overflow-y-auto rounded-lg bg-blue-50 lg:mb-3">

      <!-- Existing section for adding a new department -->
      <div class="flex items-center w-full p-4 lg:w-1/2">
        <form id="department-form" class="flex items-center w-full">
          <label for="new-department" class="sr-only">New Department</label>
          <input type="text" id="new-department" name="new-department" class="w-full p-2 transition duration-200 border-2 border-gray-300 rounded-md outline-none focus:border-blue-500" placeholder="Add new department" required>
          <button type="submit" id="add-department" class="px-4 py-2 ml-2 text-white transition duration-200 bg-blue-500 rounded-md hover:bg-blue-600">Add</button>
        </form>
      </div>

      <!-- add a sample table where i can see the department name, description, and action button    -->

      <div class="w-full p-4 lg:w-1/2">
        <div class="overflow-x-auto rounded-lg shadow-md">
          <table class="min-w-full bg-white border border-gray-300">
            <thead class="bg-blue-100">
              <tr>
                <th class="px-4 py-3 text-sm font-semibold text-left text-gray-700 border-b">Department Name</th>
                <th class="px-4 py-3 text-sm font-semibold text-center text-gray-700 border-b">Action</th>
              </tr>
            </thead>
            <tbody>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-2 text-gray-600 border-b">Department 1</td>
                <td class="px-4 py-2 text-center text-gray-600 border-b">
                  <button class="px-2 py-1 text-xs text-white bg-blue-500 rounded-md hover:bg-blue-600">Edit</button>
                  <button class="px-2 py-1 text-xs text-white bg-red-500 rounded-md hover:bg-red-600">Delete</button>
                </td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-2 text-gray-600 border-b">Department 2</td>
                <td class="px-4 py-2 text-center text-gray-600 border-b">
                  <button class="px-2 py-1 text-xs text-white bg-blue-500 rounded-md hover:bg-blue-600">Edit</button>
                  <button class="px-2 py-1 text-xs text-white bg-red-500 rounded-md hover:bg-red-600">Delete</button>
                </td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-2 text-gray-600 border-b">Department 3</td>
                <td class="px-4 py-2 text-center text-gray-600 border-b">
                  <button class="px-2 py-1 text-xs text-white bg-blue-500 rounded-md hover:bg-blue-600">Edit</button>
                  <button class="px-2 py-1 text-xs text-white bg-red-500 rounded-md hover:bg-red-600">Delete</button>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

  </main>

</body>

