<!DOCTYPE html>
<html>

<head>
  <title>Edit Certification Details</title>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/sweetalert2@11.js"></script>
  <script src="/javascript/admin/certificationEditor.js" defer></script>

</head>

<body class="min-h-screen bg-gray-50">
  <!-- Header -->
  <header class="sticky top-0 z-50 w-full shadow-lg bg-white/80 backdrop-blur-md">
    <div class="bg-gradient-to-r from-blue-800 via-blue-700 to-blue-800">
      <div class="container p-4 mx-auto max-w-7xl">
        <div class="flex items-center justify-between">
          <button onclick="history.back()" class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-white transition-all duration-300 rounded-lg shadow-sm bg-blue-700/50 hover:bg-blue-600 hover:shadow">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            <span class="hidden sm:inline">Back</span>
          </button>
          <h1 class="font-sans text-xl font-bold text-white">Edit Certification Details</h1>
          <div class="w-[72px]"></div>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="container px-4 py-6 mx-auto">
    <div class="max-w-3xl mx-auto">
      <form id="certificationForm" class="space-y-4">
        <!-- Prepared By -->
        <div class="p-4 transition-shadow duration-200 bg-white rounded-lg shadow hover:shadow-md">
          <div class="mb-2">
            <h2 class="text-base font-bold text-gray-800">Prepared By</h2>
          </div>
          <div id="preparedByContainer" class="space-y-3">
            <!-- Prepared By entries will be dynamically added here -->
          </div>
          <div class="mt-3">
            <button type="button" id="addPreparedBy" class="flex items-center px-2.5 py-1 text-sm text-white bg-blue-600 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Add Entry
            </button>
          </div>
        </div>

        <!-- Noted By -->
        <div class="p-4 transition-shadow duration-200 bg-white rounded-lg shadow hover:shadow-md">
          <div class="mb-2">
            <h2 class="text-base font-bold text-gray-800">Noted By</h2>
          </div>
          <div id="notedByContainer" class="space-y-3">
            <!-- Noted By entries will be dynamically added here -->
          </div>
          <div class="mt-3">
            <button type="button" id="addNotedBy" class="flex items-center px-2.5 py-1 text-sm text-white bg-blue-600 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Add Entry
            </button>
          </div>
        </div>

        <!-- Approved By -->
        <div class="p-4 transition-shadow duration-200 bg-white rounded-lg shadow hover:shadow-md">
          <div class="mb-2">
            <h2 class="text-base font-bold text-gray-800">Approved By</h2>
          </div>
          <div id="approvedByContainer" class="space-y-3">
            <!-- Approved By entries will be dynamically added here -->
          </div>
          <div class="mt-3">
            <button type="button" id="addApprovedBy" class="flex items-center px-2.5 py-1 text-sm text-white bg-blue-600 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Add Entry
            </button>
          </div>
        </div>

        <div class="flex justify-end pt-3 space-x-3">
          <button type="button" onclick="window.history.back()" class="px-3 py-1.5 text-sm text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500">
            Cancel
          </button>
          <button type="submit" class="px-3 py-1.5 text-sm text-white bg-blue-600 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </main>

  <!-- Footer -->
  <footer class="py-4 mt-6 text-sm text-center bg-white border-t text-slate-500 border-slate-200">
    <div class="container max-w-5xl px-4 mx-auto">
      <p>© <%= new Date().getFullYear() %> Election System. All rights reserved.</p>
    </div>
  </footer>
</body>

</html>