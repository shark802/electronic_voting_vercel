<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Election Results | <%= electionInfo.election_name %></title>
  <script src="/javascript/lib/jquery-3.7.1.min.js"></script>
  <script src="/javascript/lib/socket.io.min.js" defer></script>
  <script src="/javascript/lib/sweetalert2@11.js" defer></script>
  <script type="module" src="/javascript/voter/electionResultForVoter.js"></script>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.5s ease-out forwards;
    }

    .animate-slide-in {
      animation: slideIn 0.4s ease-out forwards;
    }

    .progress-bar-animation {
      transition: width 1s ease-out;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f5f9;
      border-radius: 8px;
    }

    ::-webkit-scrollbar-thumb {
      background: #94a3b8;
      border-radius: 8px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #64748b;
    }

    /* Image fallback styling */
    .candidate-image {
      transition: opacity 0.2s ease;
    }

    .candidate-image.hidden {
      display: none;
    }

    .candidate-initials {
      transition: opacity 0.2s ease;
    }

    .candidate-initials.hidden {
      display: none;
    }

    /* Winner rank styling */
    .winner-rank-1 {
      background: linear-gradient(135deg, #ffd700, #ffed4e);
      color: #92400e;
    }

    .winner-rank-2 {
      background: linear-gradient(135deg, #c0c0c0, #e5e7eb);
      color: #374151;
    }

    .winner-rank-3 {
      background: linear-gradient(135deg, #cd7f32, #d97706);
      color: #ffffff;
    }
  </style>
</head>

<body class="min-h-screen font-sans bg-gradient-to-br from-slate-50 to-blue-50 text-slate-800">
  <!-- Modern sticky header -->
  <header class="sticky top-0 z-50 w-full shadow-lg bg-white/80 backdrop-blur-md">
    <div class="bg-gradient-to-r from-blue-800 via-blue-700 to-blue-800">
      <div class="container px-4 mx-auto max-w-7xl">
        <div class="flex items-center justify-between h-16">
          <!-- Left side with back button and election name -->
          <div class="flex items-center space-x-4">
            <a href="/election" class="inline-flex items-center px-3 py-2 text-sm font-medium text-white transition-all duration-300 rounded-lg shadow-sm bg-blue-700/50 hover:bg-blue-600 hover:shadow">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              <span class="hidden sm:inline">Back</span>
            </a>

            <div>
              <h1 class="text-lg font-bold text-white">
                <span class="hidden sm:inline">Election Results</span>
                <span class="sm:hidden">Results</span>
              </h1>
              <p class="text-sm text-blue-200 -mt-0.5 truncate max-w-[200px] sm:max-w-xs">
                <%= electionInfo.election_name %>
              </p>
            </div>
          </div>

          <!-- Right side with status badge -->
          <div class="flex items-center">
            <% 
            const now = new Date();
            const startDate = new Date(electionInfo.date_start);
            startDate.setHours(parseInt(electionInfo.time_start.split(':')[0]), parseInt(electionInfo.time_start.split(':')[1]));
            
            const endDate = new Date(electionInfo.date_end);
            endDate.setHours(parseInt(electionInfo.time_end.split(':')[0]), parseInt(electionInfo.time_end.split(':')[1]));
            
            let statusClass = '';
            let statusText = '';
            let statusIcon = '';
            
            if (now < startDate) {
              statusClass = 'bg-blue-100 text-blue-800 border border-blue-200';
              statusText = 'Upcoming';
              statusIcon = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />';
            } else if (now > endDate) {
              statusClass = 'bg-green-100 text-green-800 border border-green-200';
              statusText = 'Completed';
              statusIcon = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />';
            } else {
              statusClass = 'bg-amber-100 text-amber-800 border border-amber-200';
              statusText = 'In Progress';
              statusIcon = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />';
            }
            %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= statusClass %> shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <%- statusIcon %>
              </svg>
              <%= statusText %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Election info bar -->
    <div class="w-full py-3 border-b shadow-sm bg-white/90 border-slate-200">
      <div class="container px-4 mx-auto max-w-7xl">
        <div class="flex flex-wrap items-center justify-between gap-y-2">
          <div class="flex flex-wrap items-center gap-4 text-sm">
            <div class="flex items-center px-3 py-1.5 rounded-lg bg-blue-50 text-blue-700 border border-blue-100">
              <svg class="w-4 h-4 mr-1.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span><%= formatDateTime(electionInfo.date_start, electionInfo.time_start) %> - <%= formatDateTime(electionInfo.date_end, electionInfo.time_end) %></span>
            </div>

            <div class="flex items-center px-3 py-1.5 rounded-lg bg-blue-50 text-blue-700 border border-blue-100">
              <svg class="w-4 h-4 mr-1.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span><%= candidatesVoteTally.length %> Candidates</span>
            </div>

            <div class="flex items-center px-3 py-1.5 rounded-lg bg-blue-50 text-blue-700 border border-blue-100">
              <svg class="w-4 h-4 mr-1.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              <span><%= positionList.length %> Positions</span>
            </div>
          </div>

          <!-- Election ID hidden input -->
          <input type="hidden" id="election-id" value="<%= electionInfo.election_id %>">

          <!-- Department info for voter -->
          <div class="flex items-center gap-2 text-sm">
            <div class="px-3 py-1.5 rounded-lg bg-slate-50 text-slate-700 border border-slate-200">
              <span class="font-medium">Your Department:</span>
              <span class="font-bold text-blue-700"><%= user.department_name %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Main content -->
  <main class="container max-w-4xl px-4 py-8 mx-auto">
    <!-- Results by position -->
    <div id="result-box" class="w-full">
      <% if (positionList && positionList.length > 0) { %>
      <% if (candidatesVoteTally.length < 1) { %>
      <!-- No results state -->
      <div class="p-8 text-center bg-white border shadow-sm border-slate-200 rounded-xl">
        <div class="inline-flex items-center justify-center w-16 h-16 mb-4 rounded-full bg-slate-100">
          <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
        <h2 class="mb-2 text-xl font-bold text-slate-800">No Results Available</h2>
        <p class="max-w-md mx-auto text-slate-600">There are no candidates or results available for this election yet. Check back later for updates.</p>
      </div>
      <% } else { %>
      <!-- Position tabs navigation -->
      <div class="mb-6 overflow-x-auto scrollbar-hide">
        <div class="inline-flex items-center min-w-full p-1 space-x-1 rounded-lg bg-slate-100 sm:min-w-0">
          <% positionList.forEach((position, idx) => { %>
          <button class="position-tab px-4 py-2 text-sm font-medium rounded-md transition-all duration-200 whitespace-nowrap <%= idx === 0 ? 'bg-white text-blue-700 shadow-sm' : 'text-slate-600 hover:bg-white/50' %>" data-position="<%= position.replace(/\s+/g, '-').toLowerCase() %>">
            <%= position %>
          </button>
          <% }); %>
        </div>
      </div>

      <!-- Results by position -->
      <div class="grid gap-6">
        <% 
            positionList.forEach((position, posIndex) => {
              // Special handling for SENATOR position - show only voter's department
              if (position === 'SENATOR') {
                // Get senator candidates for voter's department only
                const senatorCandidates = candidatesVoteTally.filter(candidate =>
                  candidate.position === position &&
                  candidate.department_name &&
                  user.department_name &&
                  candidate.department_name.toUpperCase().trim() === user.department_name.toUpperCase().trim()
                );
                
                if (senatorCandidates.length > 0) {
            %>
        <!-- SENATOR section for voter's department -->
        <section id="<%= position.replace(/\s+/g, '-').toLowerCase() %>" class="position-section overflow-hidden bg-white border border-slate-200 rounded-xl shadow-sm <%= posIndex === 0 ? 'block' : 'hidden' %> animate-fade-in" style="animation-delay: <%= (posIndex * 0.05).toFixed(2) %>s">
          <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
            <h3 class="flex items-center text-lg font-bold text-slate-800">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              SENATOR - <%= user.department_name %> Department
            </h3>
            <span class="px-3 py-1 text-xs font-medium text-blue-700 bg-blue-100 rounded-full">
              <%= senatorCandidates.length %> Candidates
            </span>
          </div>

          <div class="p-4">
            <% 
                  // Find the department data to get max_select_senator
                  const deptData = departmentData.find(d => d.department_code === user.department_name);
                  const maxSelect = deptData ? deptData.max_select_senator : 1;

                  // Sort candidates by vote count and determine winners
                  senatorCandidates.sort((a, b) => b.vote_count - a.vote_count);
                  const winners = senatorCandidates.slice(0, maxSelect).filter(c => c.vote_count > 0);
                  const winnerVoteCounts = winners.map(w => w.vote_count);

                  const totalVotesInDept = senatorCandidates.reduce((total, candidate) => 
                    total + candidate.vote_count, 0);
                %>

            <!-- Department info -->
            <div class="p-3 mb-4 border border-blue-100 rounded-lg bg-blue-50">
              <div class="flex items-center justify-between text-sm">
                <span class="text-blue-700">
                  <svg xmlns="http://www.w3.org/2000/svg" class="inline w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Top <%= maxSelect %> candidate<%= maxSelect > 1 ? 's' : '' %> will be elected from your department
                </span>
                <span class="font-medium text-blue-800"><%= totalVotesInDept %> total votes</span>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <% senatorCandidates.forEach((candidate, candIndex) => { 
                        const department = departmentsPopulation ? departmentsPopulation.find(dep => dep.program_code === candidate.department_name) : null;
                        const population = department ? department.program_population : 0;
                        const votePercentage = population === 0 ? 0 : ((candidate.vote_count / population) * 100).toFixed(2);
                        const isWinning = winnerVoteCounts.includes(candidate.vote_count) && candidate.vote_count > 0;
                        const winnerRank = isWinning ? winners.findIndex(w => w.vote_count === candidate.vote_count && w.candidate_id === candidate.candidate_id) + 1 : 0;
                      %>
              <div class="relative p-4 rounded-xl border <%= isWinning ? 'border-green-200 bg-green-50' : 'border-slate-200' %> transition-all duration-200 animate-fade-in" style="animation-delay: <%= (candIndex * 0.1).toFixed(2) %>s">
                <% if (isWinning) { %>
                <div class="absolute top-0 right-0 transform translate-x-1/4 -translate-y-1/4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-full shadow-lg <%= winnerRank === 1 ? 'winner-rank-1' : winnerRank === 2 ? 'winner-rank-2' : 'winner-rank-3' %>">
                    <span class="text-sm font-bold"><%= winnerRank %></span>
                  </div>
                </div>
                <% } %>

                <div class="flex flex-col items-center mb-3 text-center">
                  <div class="relative mb-3">
                    <% if (candidate.candidate_profile) { %>
                    <!-- Image with fallback to initials -->
                    <img class="object-cover w-16 h-16 rounded-full border-4 <%= isWinning ? 'border-green-500' : 'border-slate-200' %> candidate-image" src="/img/candidate_profiles/<%= candidate.candidate_profile %>" alt="<%= candidate.firstname %> <%= candidate.lastname %>" onerror="handleImageError(this, '<%= candidate.firstname.charAt(0) %><%= candidate.lastname.charAt(0) %>', '<%= isWinning ? 'green' : 'blue' %>')">
                    <div class="flex items-center justify-center w-16 h-16 text-lg font-bold text-white <%= isWinning ? 'bg-green-500' : 'bg-blue-500' %> rounded-full candidate-initials hidden">
                      <%= candidate.firstname.charAt(0) %><%= candidate.lastname.charAt(0) %>
                    </div>
                    <% } else { %>
                    <div class="flex items-center justify-center w-16 h-16 text-lg font-bold text-white <%= isWinning ? 'bg-green-500' : 'bg-blue-500' %> rounded-full">
                      <%= candidate.firstname.charAt(0) %><%= candidate.lastname.charAt(0) %>
                    </div>
                    <% } %>
                  </div>

                  <h4 class="text-base font-medium text-slate-900"><%= candidate.firstname %> <%= candidate.lastname %></h4>

                  <div class="flex items-center justify-center gap-2 mt-1 mb-2">
                    <% if (candidate.party) { %>
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-700"><%= candidate.party %></span>
                    <% } %>
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-700"><%= candidate.course %></span>
                  </div>

                  <div class="w-full mt-2">
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-xs text-slate-500"><%= candidate.vote_count %> votes</span>
                      <span class="text-sm font-bold <%= isWinning ? 'text-green-600' : 'text-blue-600' %>"><%= votePercentage %>%</span>
                    </div>

                    <!-- Vote percentage bar with animation -->
                    <div class="w-full h-2.5 overflow-hidden bg-slate-200 rounded-full">
                      <div class="h-full <%= isWinning ? 'bg-green-500' : 'bg-blue-500' %> rounded-full progress-bar-animation" style="width: <%= votePercentage %>%"></div>
                    </div>
                  </div>
                </div>

                <% if (isWinning) { %>
                <div class="py-1.5 px-3 text-xs font-medium text-center text-green-700 bg-green-100 rounded-lg mt-2">
                  Winner - <%= winnerRank %><%= winnerRank === 1 ? 'st' : winnerRank === 2 ? 'nd' : winnerRank === 3 ? 'rd' : 'th' %> Place
                </div>
                <% } %>
              </div>
              <% }); %>
            </div>
          </div>
        </section>
        <% 
                }
              } else {
                // Handle other positions
                const candidatePerPosition = candidatesVoteTally.filter(candidate => candidate.position === position);
                
                if (candidatePerPosition.length > 0) {
                  candidatePerPosition.sort((a, b) => b.vote_count - a.vote_count);
                  const highestVoteInPosition = candidatePerPosition.reduce((highest, currentCandidateIteration) => 
                    currentCandidateIteration.vote_count > highest ? currentCandidateIteration.vote_count : highest, 0);
                  const totalVotesInPosition = candidatePerPosition.reduce((total, candidateVotes) => 
                    total + candidateVotes.vote_count, 0);
            %>
        <section id="<%= position.replace(/\s+/g, '-').toLowerCase() %>" class="position-section overflow-hidden bg-white border border-slate-200 rounded-xl shadow-sm <%= posIndex === 0 ? 'block' : 'hidden' %> animate-fade-in" style="animation-delay: <%= (posIndex * 0.05).toFixed(2) %>s">
          <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
            <h3 class="flex items-center text-lg font-bold text-slate-800">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              <%= position %>
            </h3>
            <span class="px-3 py-1 text-xs font-medium text-blue-700 bg-blue-100 rounded-full">
              <%= candidatePerPosition.length %> Candidates
            </span>
          </div>

          <div class="p-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <% candidatePerPosition.forEach((candidate, index) => { 
                      const votePercentage = electionInfo.total_populations === 0 ? 0 : ((candidate.vote_count / electionInfo.total_populations) * 100).toFixed(2);
                      const isWinning = candidate.vote_count === highestVoteInPosition && candidate.vote_count > 0;
                    %>
              <div class="relative p-4 rounded-xl border <%= isWinning ? 'border-green-200 bg-green-50' : 'border-slate-200' %> transition-all duration-200 animate-fade-in" style="animation-delay: <%= (index * 0.1).toFixed(2) %>s">
                <% if (isWinning) { %>
                <div class="absolute top-0 right-0 transform translate-x-1/4 -translate-y-1/4">
                  <div class="flex items-center justify-center w-10 h-10 bg-green-500 rounded-full shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                </div>
                <% } %>

                <div class="flex flex-col items-center mb-3 text-center">
                  <div class="relative mb-3">
                    <% if (candidate.candidate_profile) { %>
                    <!-- Image with fallback to initials -->
                    <img class="object-cover w-16 h-16 rounded-full border-4 <%= isWinning ? 'border-green-500' : 'border-slate-200' %> candidate-image" src="/img/candidate_profiles/<%= candidate.candidate_profile %>" alt="<%= candidate.firstname %> <%= candidate.lastname %>" onerror="handleImageError(this, '<%= candidate.firstname.charAt(0) %><%= candidate.lastname.charAt(0) %>', '<%= isWinning ? 'green' : 'blue' %>')">
                    <div class="flex items-center justify-center w-16 h-16 text-lg font-bold text-white <%= isWinning ? 'bg-green-500' : 'bg-blue-500' %> rounded-full candidate-initials hidden">
                      <%= candidate.firstname.charAt(0) %><%= candidate.lastname.charAt(0) %>
                    </div>
                    <% } else { %>
                    <div class="flex items-center justify-center w-16 h-16 text-lg font-bold text-white <%= isWinning ? 'bg-green-500' : 'bg-blue-500' %> rounded-full">
                      <%= candidate.firstname.charAt(0) %><%= candidate.lastname.charAt(0) %>
                    </div>
                    <% } %>
                  </div>

                  <h4 class="text-base font-medium text-slate-900"><%= candidate.firstname %> <%= candidate.lastname %></h4>

                  <div class="flex items-center justify-center gap-2 mt-1 mb-2">
                    <% if (candidate.party) { %>
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-700"><%= candidate.party %></span>
                    <% } %>
                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-700"><%= candidate.course %></span>
                  </div>

                  <div class="w-full mt-2">
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-xs text-slate-500"><%= candidate.vote_count %> votes</span>
                      <span class="text-sm font-bold <%= isWinning ? 'text-green-600' : 'text-blue-600' %>"><%= votePercentage %>%</span>
                    </div>

                    <!-- Vote percentage bar with animation -->
                    <div class="w-full h-2.5 overflow-hidden bg-slate-200 rounded-full">
                      <div class="h-full <%= isWinning ? 'bg-green-500' : 'bg-blue-500' %> rounded-full progress-bar-animation" style="width: <%= votePercentage %>%"></div>
                    </div>
                  </div>
                </div>

                <% if (isWinning) { %>
                <div class="py-1.5 px-3 text-xs font-medium text-center text-green-700 bg-green-100 rounded-lg mt-2">
                  Winner
                </div>
                <% } %>
              </div>
              <% }); %>
            </div>
          </div>
        </section>
        <% 
                }
              }
            });
            %>
      </div>
      <% } %>
      <% } else { %>
      <!-- No positions available state -->
      <div class="p-8 text-center bg-white border shadow-sm border-slate-200 rounded-xl">
        <div class="inline-flex items-center justify-center w-16 h-16 mb-4 rounded-full bg-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h2 class="mb-2 text-xl font-bold text-slate-800">No Positions Available</h2>
        <p class="max-w-md mx-auto text-slate-600">No positions or results are available for this election. Please check back later or contact the administrator.</p>
      </div>
      <% } %>
    </div>
  </main>

  <!-- Modern footer -->
  <footer class="py-6 mt-8 text-sm text-center bg-white border-t text-slate-500 border-slate-200">
    <div class="container max-w-4xl px-4 mx-auto">
      <p class="font-medium">© <%= new Date().getFullYear() %> BCC Web-based E-voting System. All rights reserved.</p>
    </div>
  </footer>

  <%
  function formatDateTime(date, time) {
    const [hours, minutes] = time.split(':');
    const dateTime = new Date(date);
    dateTime.setHours(parseInt(hours), parseInt(minutes));
    return dateTime.toLocaleString('en-US', { 
      dateStyle: 'medium', 
      timeStyle: 'short' 
    });
  }
  %>

  <!-- JavaScript for interactive features -->
  <script>
    // Image error handling function
    function handleImageError(img, initials, colorTheme) {
      // Hide the failed image
      img.classList.add('hidden');

      // Show the initials fallback
      const initialsDiv = img.nextElementSibling;
      if (initialsDiv && initialsDiv.classList.contains('candidate-initials')) {
        initialsDiv.classList.remove('hidden');

        // Update the color theme if needed
        if (colorTheme === 'green') {
          initialsDiv.classList.remove('bg-blue-500', 'bg-amber-500');
          initialsDiv.classList.add('bg-green-500');
        } else if (colorTheme === 'amber') {
          initialsDiv.classList.remove('bg-blue-500', 'bg-green-500');
          initialsDiv.classList.add('bg-amber-500');
        } else {
          initialsDiv.classList.remove('bg-green-500', 'bg-amber-500');
          initialsDiv.classList.add('bg-blue-500');
        }
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      // Position tabs functionality
      const positionTabs = document.querySelectorAll('.position-tab');
      const positionSections = document.querySelectorAll('.position-section');

      positionTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Update active tab
          positionTabs.forEach(t => t.classList.remove('bg-white', 'text-blue-700', 'shadow-sm'));
          tab.classList.add('bg-white', 'text-blue-700', 'shadow-sm');

          // Show corresponding section
          const targetPosition = tab.dataset.position;
          positionSections.forEach(section => {
            if (section.id === targetPosition) {
              section.classList.remove('hidden');
              section.classList.add('block', 'animate-fade-in');
            } else {
              section.classList.add('hidden');
              section.classList.remove('block');
            }
          });
        });
      });

      // Animate progress bars on load
      const progressBars = document.querySelectorAll('.progress-bar-animation');
      setTimeout(() => {
        progressBars.forEach(bar => {
          const width = bar.style.width;
          bar.style.width = '0';
          setTimeout(() => {
            bar.style.width = width;
          }, 100);
        });
      }, 500);
    });
  </script>
</body>

</html>