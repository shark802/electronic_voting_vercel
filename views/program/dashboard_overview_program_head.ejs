<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Election Overview</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/javascript/lib/jquery-3.7.1.min.js" defer></script>
  <script src="/javascript/lib/sweetalert2@11.js" defer></script>
  <script src="/javascript/lib/socket.io.min.js"></script>
  <script type="module" src="/javascript/admin/dashboard_overview.js" defer></script>

  <style>
    #manage-population-modal::backdrop {
      background-color: rgba(0, 0, 0, 0.3);
    }
  </style>
</head>

<body class="w-[100vw] m-0 bg-blue-600 dvh flex overflow-hidden">

  <div id="sidebar" class="absolute z-10 w-full bg-black rounded-tr-md rounded-br-md bg-opacity-40 lg:block h-dvh lg:relative lg:w-1/5">

    <svg id="hide-sidebar" xmlns="http://www.w3.org/2000/svg" class="absolute w-10 h-10 m-2 bg-opacity-50 rounded-md right-4 top-4 bg-slate-500 lg:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>

    <nav class="relative z-10 flex flex-col w-4/5 px-2 pt-2 font-sans bg-white rounded-tr-lg rounded-br-lg h-dvh lg:w-full">

      <div class="text-white rounded-md bg-gradient-to-r from-blue-600 to-blue-800">
        <div class="flex items-center justify-between p-4">
          <div class="flex items-center space-x-3">
            <img src="/img/bcc-logo.webp" alt="BCC Logo" class="w-10 h-10 p-1 bg-white rounded-full">
            <div>
              <h1 class="text-sm font-bold leading-tight">BCC WEB BASED E-VOTING</h1>
              <p class="text-xs text-blue-200">WITH FACE RECOGNITION</p>
            </div>
          </div>
          <button id="hide-sidebar" class="p-2 text-white rounded-full hover:bg-blue-700 lg:hidden focus:outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="px-4 py-2 bg-blue-800 bg-opacity-50 rounded-md">
          <p class="text-sm font-medium">Program Head Dashboard</p>
        </div>
      </div>

      <hr class="my-4 border-gray-200">

      <ul class="no-scrollbar overflow-auto overflow-x-hidden max-h-[77%] scroll-m-0 py-2 space-y-1">

        <li class="w-full">
          <div class="relative block w-full">
            <a href="/program-head/dashboard/overview" class="flex items-center px-4 py-2 text-gray-700 transition-colors duration-150 ease-in-out rounded-md hover:bg-gray-100 hover:text-gray-900">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
              <span id="dashboard_nav" class="text-sm font-medium">Dashboard</span>
            </a>
            <div id="dashboard_subpage" class="pl-4 mt-1 space-y-1 border-l-2 border-gray-400 ml-7">
              <a id="overview_page" href="/program-head/dashboard/overview" class="block py-1 pl-2 text-sm text-gray-600 hover:text-gray-900">Overview</a>
              <a id="vote_tally_page" href="/program-head/dashboard/vote-tally" class="block py-1 pl-2 text-sm text-gray-600 hover:text-gray-900">Vote Tally</a>
            </div>
          </div>
        </li>

      </ul>

      <div class="p-4 mt-auto border-t border-gray-200">
        <button id="logout-button" class="flex items-center justify-center w-full px-4 py-2 text-sm font-medium text-white transition-colors duration-150 ease-in-out bg-red-600 rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" class="w-6 h-6 mr-2">
            <path d="M9.00195 7C9.01406 4.82497 9.11051 3.64706 9.87889 2.87868C10.7576 2 12.1718 2 15.0002 2L16.0002 2C18.8286 2 20.2429 2 21.1215 2.87868C22.0002 3.75736 22.0002 5.17157 22.0002 8L22.0002 16C22.0002 18.8284 22.0002 20.2426 21.1215 21.1213C20.2429 22 18.8286 22 16.0002 22H15.0002C12.1718 22 10.7576 22 9.87889 21.1213C9.11051 20.3529 9.01406 19.175 9.00195 17" stroke-width="1.5" stroke-linecap="round"></path>
            <path d="M15 12L2 12M2 12L5.5 9M2 12L5.5 15" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span>Logout</span>
        </button>
      </div>
    </nav>
  </div>

  <main class="relative flex flex-col w-full m-auto overflow-y-auto lg:w-4/5 no-scrollbar h-dvh lg:px-2">

    <header class="sticky top-0 flex items-center justify-between w-full px-4 py-3 bg-blue-600 shadow-md lg:h-20 lg:px-6">
      <button id="show-sidebar" class="p-2 text-white transition-colors duration-200 rounded-md lg:hidden hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" aria-label="Toggle sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <h1 class="font-sans text-2xl font-bold text-white lg:text-3xl">Election Overview</h1>

    </header>

    <div id="overview-container" class="relative h-full p-2 mt-3 overflow-hidden overflow-x-hidden overflow-y-auto rounded-lg lg:p-5 lg:mb-2 bg-blue-50 no-scrollbar">

      <% if (elections && elections.length > 0) { 
        elections.forEach(election => { %>

      <section id="election-section" data-election-id="<%= election.election_id %>" class="pb-3 mb-12 border-2 rounded-md">
        <input id="date-end" type="hidden" value="<%= election.date_end %>">
        <input id="time-end" type="hidden" value="<%= election.time_end %>">

        <div class="flex items-center justify-between p-4 text-white rounded-lg shadow-lg bg-gradient-to-r from-blue-600 to-blue-700">
          <div>
            <h2 class="text-xl font-bold lg:text-2xl"><%= election.election_name %></h2>
            <p id="election-id" class="mt-1 text-sm text-blue-100 opacity-80"><%= election.election_id %></p>
          </div>
          <div class="flex items-center space-x-2">
            <span id="election-status" class="px-3 py-1 text-xs font-medium bg-blue-500 rounded-full"><%= election.is_active ? 'Active' : 'Inactive' %></span>

          </div>
        </div>

        <div class="flex flex-grow w-full gap-2 px-2 py-3 mt-3 lg:px-4 lg:gap-4 lg:py-4">

          <div class="w-1/3 p-3 border-2 border-blue-700 rounded-lg bg-gradient-to-r from-blue-600 to-blue-700 lg:p-6 min-h-24">
            <div class="flex flex-col items-center lg:flex-row lg:items-center">
              <svg class="w-6 h-6 mb-2 text-white lg:w-10 lg:h-10 lg:mb-0 lg:mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <div class="flex flex-col items-center lg:flex-row lg:items-baseline">
                <p id="total-population" class="text-2xl font-bold text-white lg:text-4xl"><%= election.total_populations || "N/A" %></p>
                <p id="total-population-percentage" class="text-sm font-medium text-blue-200 lg:text-xl lg:ml-2"></p>
              </div>
            </div>
            <p class="mt-3 text-xs font-bold tracking-wider text-center text-blue-200 uppercase lg:text-left lg:text-sm">Total students</p>
          </div>

          <div class="w-1/3 p-3 border-2 border-green-500 rounded-lg bg-gradient-to-r from-green-600 to-green-700 lg:p-6 min-h-24">
            <div class="flex flex-col items-center lg:flex-row lg:items-center">
              <svg class="w-6 h-6 mb-2 text-white lg:w-10 lg:h-10 lg:mb-0 lg:mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
              <div class="flex flex-col items-center lg:flex-row lg:items-baseline">
                <p id="total-voted" class="text-2xl font-bold text-white lg:text-4xl">0</p>
                <p id="total-voted-percentage" class="text-sm font-medium text-green-200 lg:text-xl lg:ml-2">(0.00%)</p>
              </div>
            </div>
            <p class="mt-3 text-xs font-bold tracking-wider text-center text-green-200 uppercase lg:text-left lg:text-sm">Voted</p>
          </div>

          <div class="w-1/3 p-3 border-2 border-red-500 rounded-lg bg-gradient-to-r from-red-600 to-red-700 lg:p-6 min-h-24">
            <div class="flex flex-col items-center lg:flex-row lg:items-center">
              <svg class="w-6 h-6 mb-2 text-white lg:w-10 lg:h-10 lg:mb-0 lg:mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path strokeLinecap="round" strokeLinejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
              <div class="flex flex-col items-center lg:flex-row lg:items-baseline">
                <p id="number-of-not-voted" class="text-2xl font-bold text-white lg:text-4xl">N/A</p>
                <p id="total-not-voted-percentage" class="text-sm font-medium text-red-200 lg:text-xl lg:ml-2">(N/A)</p>
              </div>
            </div>
            <p class="mt-3 text-xs font-bold tracking-wider text-center text-red-200 uppercase lg:text-left lg:text-sm">Not voted</p>
          </div>

        </div>

        <div class="grid gap-1 px-1 py-2 lg:gap-2 lg:px-3">
          <% populationPerProgram.filter(program => program.election_id === election.election_id && program.program_code === user.course).forEach(course => { %>
          <div id="program" class="w-full bg-white rounded-lg shadow-md overflow-hidden transition-all duration-300 hover:shadow-lg hover:scale-[1.02] group">
            <div class="flex flex-col lg:flex-row">
              <div id="program-code" data-program-code="<%= course.program_code %>" class="flex items-center justify-center text-2xl font-bold text-white bg-blue-600 lg:py-5 lg:px-6 lg:w-1/4">
                <div class="text-center">
                  <p class="mb-1 text-lg font-bold lg:text-3xl"><%= course.program_code %></p>
                  <p class="text-xs tracking-wider uppercase opacity-75">Department</p>
                </div>
              </div>
              <div class="flex flex-grow w-full gap-2 p-4 lg:gap-4 lg:py-5">
                <div class="flex-1 text-center">
                  <p id="program-population" class="text-lg font-bold text-gray-800 lg:text-3xl"><%= course.program_population === 0 ? 'N/A' : course.program_population %></p>
                  <p class="text-sm font-medium text-gray-500">Total voters</p>
                </div>

                <div class="relative flex-1 text-center">
                  <p id="departmentTotalVotes" class="text-lg font-bold text-green-600 lg:text-3xl">0</p>
                  <p class="text-sm font-medium text-gray-500">Voted</p>
                  <a href="/report/program/voter/<%= election.election_id %>?voteStatus=voted&department=<%= course.program_code %>">
                    <button class="absolute bottom-0 px-3 py-1 text-xs text-green-700 transition-opacity duration-300 ease-in-out transform -translate-x-1/2 bg-green-100 rounded-md opacity-0 left-1/2 group-hover:opacity-100 hover:bg-green-200">
                      View Report
                    </button>
                  </a>
                </div>

                <div class="relative flex-1 text-center">
                  <p id="departmentNumberOfNotVoted" class="text-lg font-bold text-red-600 lg:text-3xl"><%= course.program_population === 0 ? 'N/A' : course.program_population %></p>
                  <p class="text-sm font-medium text-gray-500">Not voted</p>
                  <a href="/report/program/voter/<%= election.election_id %>?voteStatus=not-voted&department=<%= course.program_code %>">
                    <button class="absolute bottom-0 px-3 py-1 text-xs text-red-700 transition-opacity duration-300 ease-in-out transform -translate-x-1/2 bg-red-100 rounded-md opacity-0 left-1/2 group-hover:opacity-100 hover:bg-red-200">
                      View Report
                    </button>
                  </a>
                </div>

              </div>
            </div>
          </div>
          <% }) %>
        </div>

      </section>

      <% }) } else { %>

      <section class="max-w-2xl mx-auto mt-5 overflow-hidden bg-white rounded-lg shadow-md">
        <div class="p-8 text-center w-[90%] m-auto">
          <img src="/img/empty-folder.webp" alt="Empty folder" class="w-24 h-24 mx-auto mb-6 opacity-75">
          <h1 class="mb-4 text-2xl font-bold text-gray-800">No Elections Scheduled</h1>
          <p class="mb-6 text-gray-600">It seems there are no elections scheduled at the moment. Would you like to create a new one?</p>

        </div>
      </section>

      <% } %>

    </div>

  </main>

</body>

</html>